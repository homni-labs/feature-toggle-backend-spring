  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "loginTheme": "feature-toggle",
  "clients": [
    {
      "clientId": "feature-toggle-frontend",
      "name": "Feature Toggle Frontend",
      "enabled": true,
      "publicClient": true,
      "attributes": {
        "login_theme": "feature-toggle"
      },
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3000/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:5173"],
      "defaultClientScopes": ["openid", "email", "profile"],
      "optionalClientScopes": []
    },
    {
      "clientId": "backend",
